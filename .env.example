# ───────────────────────────────────────────────────────────────────────────
# UX KPI Intelligence Tool — environment template
# Copy to `.env.local` and fill in real values. NEVER commit `.env.local`.
# ───────────────────────────────────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — must NEVER be exposed to the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# AI APIs
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=
HUGGINGFACE_API_KEY=
# Qwen (Alibaba DashScope) — key enables the Qwen service
QWEN_API_KEY=
# Ollama (local LLM) — base URL, e.g. http://localhost:11434
OLLAMA_BASE_URL=

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Phase 3 Integrations (optional — leave blank to keep integrations in "not connected" state)
MURAL_API_KEY=
FIGMA_ACCESS_TOKEN=
JIRA_BASE_URL=
JIRA_API_TOKEN=
CONFLUENCE_API_TOKEN=
